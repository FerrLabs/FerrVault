{
  "$schema": "https://ferrflow.com/schema/ferrflow.json",
  "workspace": {
    "recoverMissedReleases": true,
    "skipCi": false,
    "floatingTags": ["major"]
  },
  "package": [
    {
      "name": "ferrflow-operator",
      "path": ".",
      "changelog": "CHANGELOG.md",
      "versionedFiles": [
        { "path": "go.mod", "format": "gomod" }
      ]
    }
  ]
}
